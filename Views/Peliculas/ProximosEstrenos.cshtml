@using PNT1_TP_Cine.Models
@model List<PNT1_TP_Cine.Models.Pelicula>
@{
    ViewData["Title"] = "PróximosEstrenos";
}
<style>
    .card:hover .card-body {
        background-color: white;
        transition: all 0.3s ease-in-out;
        cursor: pointer;
        color: black;
    }
</style>
<section id="coming-soon" class="container py-5 mt-5 text-white">
    <<div class="text-center">
        <h3 class="mb-4">PRÓXIMOS ESTRENOS</h3>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
            @foreach (var pelicula in Model)
            {
                <div class="col">
                    <div class="card h-100 bg-dark text-white rounded-4 d-flex flex-column position-relative overflow-hidden">
                        <div style="height: 300px; overflow: hidden;">
                            <img src="@pelicula.Imagen" class="w-100 h-100 object-fit-cover rounded-top-4"
                                 alt="@pelicula.Titulo"
                                 onerror="this.src='https://via.placeholder.com/300x450?text=Imagen+no+disponible'" />
                        </div>

                        <div class="position-absolute top-0 end-0 m-2">
                            <span class="badge bg-warning text-dark">PRÓXIMAMENTE</span>
                        </div>

                        <div class="card-body d-flex flex-column justify-content-between rounded-bottom-4">
                            <h5 class="card-title text-uppercase">@pelicula.Titulo</h5>
                            <p class="card-text">
                                <small class="text-secondary">Estreno: @pelicula.FechaEstreno.ToString("dd/MM/yyyy")</small>
                            </p>
                            <a href="@Url.Action("Detalle", "Peliculas", new { titulo = pelicula.Titulo })"
                               class="btn btn-outline-light bg-dark mt-3 text-decoration-none text-white">
                                <i class="fas fa-info-circle me-2"></i>Ver más
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info text-center py-4">
            <i class="fas fa-film fa-3x mb-3"></i>
            <h4>No hay próximos estrenos programados</h4>
            <p class="mb-0">Vuelve a consultar más adelante</p>
        </div>
    }
</section>

<style>
    /* Estilos para el badge */
    .badge {
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.5px;
    }
</style>